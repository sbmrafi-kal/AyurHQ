{% doc %}
  Renders all meta tags for the page including Open Graph, Twitter Cards, and SEO tags.

  @param {object} [product] - The product object, available on product pages for price meta tags.
{% enddoc %}

<meta charset="utf-8">
<meta
  http-equiv="X-UA-Compatible"
  content="IE=edge"
>
<meta
  name="viewport"
  content="width=device-width,initial-scale=1"
>
<meta
  name="view-transition"
  content="same-origin"
>
<meta
  name="theme-color"
  content=""
>

{%- liquid
  assign og_title = page_title | default: shop.name
  assign og_url = canonical_url | default: request.origin
  assign og_type = 'website'
  assign og_description = page_description | default: shop.description | default: shop.name

  if request.page_type == 'product'
    assign og_type = 'product'
  elsif request.page_type == 'article'
    assign og_type = 'article'
  elsif request.page_type == 'password'
    assign og_url = request.origin
  endif
%}

<meta
  property="og:site_name"
  content="{{ shop.name }}"
>
<meta
  property="og:url"
  content="{{ og_url }}"
>
<meta
  property="og:title"
  content="{{ og_title | escape }}"
>
<meta
  property="og:type"
  content="{{ og_type }}"
>
<meta
  property="og:description"
  content="{{ og_description | escape }}"
>

{%- if page_image -%}
  <meta
    property="og:image"
    content="http:{{ page_image | image_url }}"
  >
  <meta
    property="og:image:secure_url"
    content="https:{{ page_image | image_url }}"
  >
  <meta
    property="og:image:width"
    content="{{ page_image.width }}"
  >
  <meta
    property="og:image:height"
    content="{{ page_image.height }}"
  >
{%- endif -%}

{%- if request.page_type == 'product' -%}
  <meta
    property="og:price:amount"
    content="{{ product.price | money_without_currency | strip_html }}"
  >
  <meta
    property="og:price:currency"
    content="{{ cart.currency.iso_code }}"
  >
{%- endif -%}

{%- if settings.social_twitter_link != blank -%}
  <meta
    name="twitter:site"
    content="{{ settings.social_twitter_link | split: 'twitter.com/' | last | prepend: '@' }}"
  >
{%- endif -%}
<meta
  name="twitter:card"
  content="summary_large_image"
>
<meta
  name="twitter:title"
  content="{{ og_title | escape }}"
>
<meta
  name="twitter:description"
  content="{{ og_description | escape }}"
>

<title>
  {%- assign custom_title = '' -%}
  {%- assign current_path = request.path -%}
  {%- if current_path == blank -%}
    {%- if canonical_url contains '/blogs/' -%}
      {%- assign blog_part = canonical_url | split: '/blogs/' | last | split: '?' | first -%}
      {%- assign current_path = '/blogs/' | append: blog_part -%}
    {%- endif -%}
  {%- endif -%}

  {%- if current_path contains '/blogs/' -%}
    {%- if current_path contains '/tagged/' or current_path contains '/tag/' -%}
      {%- assign tag_part = current_path | split: '/tagged/' | last | split: '/tag/' | last | split: '?' | first | split: '/' | first | handle -%}
      {%- if tag_part == 'digestion' or tag_part == 'digestion-gut' -%}
        {%- assign custom_title = 'Digestion & gut' -%}
      {%- elsif tag_part == 'food' or tag_part == 'food-kitchen' -%}
        {%- assign custom_title = 'Food & kitchen' -%}
      {%- elsif tag_part == 'herbs' or tag_part == 'herbs-remedies' -%}
        {%- assign custom_title = 'Herbs & remedies' -%}
      {%- elsif tag_part == 'weight' or tag_part == 'weight-cravings' -%}
        {%- assign custom_title = 'Weight & cravings' -%}
      {%- elsif tag_part == 'seasons' or tag_part == 'seasons-routine' -%}
        {%- assign custom_title = 'Seasons & routine' -%}
      {%- elsif tag_part == 'sleep' or tag_part == 'sleep-energy' -%}
        {%- assign custom_title = 'Sleep & energy' -%}
      {%- elsif tag_part == 'mind' or tag_part == 'mind-calm' -%}
        {%- assign custom_title = 'Mind & calm' -%}
      {%- elsif tag_part == 'habits' or tag_part == 'daily-habits' -%}
        {%- assign custom_title = 'Daily habits' -%}
      {%- elsif tag_part == 'joints' or tag_part == 'joints-body' -%}
        {%- assign custom_title = 'Joints & body' -%}
      {%- elsif tag_part == 'skin' or tag_part == 'skin-glow' -%}
        {%- assign custom_title = 'Skin & glow' -%}
      {%- elsif tag_part == 'hair' or tag_part == 'hair-scalp' -%}
        {%- assign custom_title = 'Hair & scalp' -%}
      {%- elsif tag_part == 'eyes' or tag_part == 'eyes-ears-mouth' -%}
        {%- assign custom_title = 'Eyes, ears & mouth' -%}
      {%- elsif tag_part == 'womens' or tag_part == 'womens-wellbeing' -%}
        {%- assign custom_title = "Women's wellbeing" -%}
      {%- elsif tag_part == 'mens' or tag_part == 'mens-wellbeing' -%}
        {%- assign custom_title = "Men's wellbeing" -%}
      {%- elsif tag_part == 'children' or tag_part == 'childrens-care' -%}
        {%- assign custom_title = "Children's care" -%}
      {%- elsif tag_part == 'elder' or tag_part == 'elder-care' -%}
        {%- assign custom_title = 'Elder care' -%}
      {%- elsif tag_part == 'basics' or tag_part == 'ayurveda-basics' -%}
        {%- assign custom_title = 'Ayurveda basics' -%}
      {%- else -%}
        {%- assign custom_title = tag_part | replace: '-', ' ' | capitalize -%}
      {%- endif -%}
      {%- assign custom_title = custom_title | append: ' · Ayurveda' -%}
    {%- else -%}
      {%- assign parts = current_path | split: '/' -%}
      {%- assign last_part = parts | last | split: '?' | first -%}
      {%- if last_part != 'news' and last_part != 'ayurveda' and last_part != blank -%}
        {%- assign custom_title = last_part | replace: '-', ' ' | capitalize | append: ' · Ayurveda' -%}
      {%- endif -%}
    {%- endif -%}
  {%- endif -%}

  {%- if custom_title != blank -%}
    {{ custom_title }} &ndash; {{ shop.name }}
  {%- elsif request.page_type == 'blog' -%}
    Blogs - AyurHQ
  {%- else -%}
    {{ page_title }}
    {%- if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif -%}
    {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif -%}
    {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
  {%- endif -%}
</title>

<link
  rel="canonical"
  href="{{ canonical_url }}"
>

{% if page_description %}
  <meta
    name="description"
    content="{{ page_description | escape }}"
  >
{% endif %}
