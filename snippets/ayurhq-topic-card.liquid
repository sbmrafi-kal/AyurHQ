{% comment %}
  Renders an Ayurveda topic card.
  Accepts:
  - topic_card: {Metaobject} The topic card metaobject reference (ayurhq_topic_card type)
{% endcomment %}

{%- if topic_card != blank -%}
  {%- assign tc = topic_card.value -%}
  <a href="{{ tc.link | default: '#' }}" class="ayurhq-blog-topic-card">
    {%- if tc.image != blank -%}
      <div class="ayurhq-blog-topic-card__image-wrapper">
        {{ tc.image | image_url: width: 400 | image_tag: 
          loading: 'lazy', 
          sizes: '(min-width: 769px) 25vw, (min-width: 481px) 50vw, 100vw', 
          class: 'ayurhq-blog-topic-card__image' 
        }}
      </div>
    {%- else -%}
      <div class="ayurhq-blog-topic-card__image-placeholder"></div>
    {%- endif -%}
    <div class="ayurhq-blog-topic-card__content">
      <h3 class="ayurhq-blog-topic-card__title">
        {{ tc.title }}
        {%- if tc.article_count != blank -%}
          <span class="ayurhq-blog-topic-card__count">{{ tc.article_count | split: ' ' | first }}</span>
        {%- endif -%}
      </h3>
      {%- if tc.hindi_title != blank -%}
        <div class="ayurhq-blog-topic-card__footer">
          <span class="ayurhq-blog-topic-card__hindi">{{ tc.hindi_title }}</span>
        </div>
      {%- endif -%}
    </div>
  </a>
{%- endif -%}
