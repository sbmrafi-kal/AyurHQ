{{ 'ayurhq-article-template.css' | asset_url | stylesheet_tag }}

{%- if article != blank -%}
<div class="ayurhq-article-wrapper">
  <div class="ayurhq-article-container">
    
    <!-- Navigation Back Pill -->
    {%- if article.image != blank -%}
      <div class="ayurhq-article-hero">
        <nav class="ayurhq-article-back-nav">
          <a href="{{ blog.url }}" class="ayurhq-article-back-pill">
            <span>← Ayurveda</span>
          </a>
        </nav>
        <div class="ayurhq-article-hero__image-wrapper">
          {{ article.image | image_url: width: 1120 | image_tag: 
            loading: 'eager', 
            class: 'ayurhq-article-hero__image',
            sizes: '100vw',
            widths: '480, 768, 1024, 1200, 1600'
          }}
        </div>
      </div>
    {%- else -%}
      <nav class="ayurhq-article-back-nav no-hero-image">
        <a href="{{ blog.url }}" class="ayurhq-article-back-pill">
          <span>← Ayurveda</span>
        </a>
      </nav>
    {%- endif -%}

    <div class="ayurhq-article-layout">
      <div class="ayurhq-article-main-column">
        
        <!-- Post Header Details -->
        <header class="ayurhq-article-header">
          {%- if article.metafields.custom.hero_badge != blank -%}
            <span class="ayurhq-article-header__badge">{{ article.metafields.custom.hero_badge.value }}</span>
          {%- endif -%}
          
          <h1 class="ayurhq-article-header__title">{{ article.title }}</h1>
          
          {%- if article.metafields.custom.hindi_title != blank -%}
            <p class="ayurhq-article-header__hindi">{{ article.metafields.custom.hindi_title.value }}</p>
          {%- endif -%}

          {%- if article.excerpt != blank -%}
            <p class="ayurhq-article-header__excerpt">{{ article.excerpt | strip_html }}</p>
          {%- endif -%}

          <div class="ayurhq-article-meta">
            <span class="ayurhq-article-meta__item">By {{ article.author }}</span>
            <span class="ayurhq-article-meta__separator">•</span>
            <span class="ayurhq-article-meta__item">{{ article.published_at | time_tag: '%B %d, %Y' }}</span>
            {%- if article.metafields.custom.read_time != blank -%}
              <span class="ayurhq-article-meta__separator">•</span>
              <span class="ayurhq-article-meta__item">{{ article.metafields.custom.read_time.value }} read</span>
            {%- endif -%}
            {%- if article.metafields.custom.review_label != blank -%}
              <span class="ayurhq-article-meta__separator">•</span>
              <span class="ayurhq-article-meta__item ayurhq-article-meta__review-badge">
                {{ article.metafields.custom.review_label.value }}
              </span>
            {%- endif -%}
          </div>
        </header>

        <!-- At A Glance Section -->
        {%- if article.metafields.custom.at_a_glance.value != blank -%}
          <section class="ayurhq-article-glance">
            <h2 class="ayurhq-article-glance__title">At a Glance</h2>
            <ul class="ayurhq-article-glance__list">
              {%- for bullet in article.metafields.custom.at_a_glance.value -%}
                {%- assign b_val = bullet.value -%}
                {%- if b_val.text != blank -%}
                  <li class="ayurhq-article-glance__item">{{ b_val.text | newline_to_br }}</li>
                {%- endif -%}
              {%- endfor -%}
            </ul>
          </section>
        {%- endif -%}

        <!-- Visual Explainer Block -->
        {%- if article.metafields.custom.visual_explainer.value != blank -%}
          {%- assign explainer = article.metafields.custom.visual_explainer.value -%}
          {%- assign downcase_heading = explainer.heading | downcase -%}
          {%- assign downcase_eyebrow = explainer.eyebrow | downcase -%}
          {%- if downcase_heading contains 'agni' or downcase_heading contains 'digestive fire' or downcase_eyebrow contains 'agni' or downcase_eyebrow contains 'digestive fire' -%}
            <section class="ayurhq-article-explainer ayurhq-agni-card">
              {%- if explainer.eyebrow != blank -%}
                <span class="ayurhq-article-explainer__eyebrow">{{ explainer.eyebrow }}</span>
              {%- endif -%}
              {%- if explainer.heading != blank -%}
                <h2 class="ayurhq-article-explainer__heading">{{ explainer.heading }}</h2>
              {%- endif -%}
              
              <div class="ayurhq-agni-card-content">
                <div class="ayurhq-agni-gauge-wrapper">
                  <svg class="ayurhq-agni-gauge" viewBox="0 0 200 110" width="200" height="110">
                    <!-- Left Arc: Low / manda (Blue #2E5B93) -->
                    <path d="M 20 90 A 80 80 0 0 1 70 20.72" fill="none" stroke="#2E5B93" stroke-width="12" stroke-linecap="round" />
                    <!-- Middle region: Balanced / sama (Soft Beige #EADCC8) -->
                    <path d="M 70 20.72 A 80 80 0 0 1 130 20.72" fill="none" stroke="#EADCC8" stroke-width="12" />
                    <!-- Right Arc: Sharp / tikshna (Orange #C8521B) -->
                    <path d="M 130 20.72 A 80 80 0 0 1 180 90" fill="none" stroke="#C8521B" stroke-width="12" stroke-linecap="round" />
                    
                    <!-- Gauge Center Cap (Black) -->
                    <circle cx="100" cy="90" r="8" fill="#1F1E1C" />
                    
                    <!-- Needle pointing straight up for balanced -->
                    <line x1="100" y1="90" x2="100" y2="35" stroke="#1F1E1C" stroke-width="4" stroke-linecap="round" />
                  </svg>
                </div>
                
                <div class="ayurhq-agni-legend">
                  <div class="ayurhq-agni-legend-item">
                    <span class="ayurhq-agni-dot" style="background-color: #2E5B93;"></span>
                    <span class="ayurhq-agni-legend-bold">Low</span>
                    <span class="ayurhq-agni-legend-gray">manda</span>
                  </div>
                  <div class="ayurhq-agni-legend-item">
                    <span class="ayurhq-agni-dot" style="background-color: #EADCC8;"></span>
                    <span class="ayurhq-agni-legend-bold">Balanced</span>
                    <span class="ayurhq-agni-legend-gray">sama</span>
                  </div>
                  <div class="ayurhq-agni-legend-item">
                    <span class="ayurhq-agni-dot" style="background-color: #C8521B;"></span>
                    <span class="ayurhq-agni-legend-bold">Sharp</span>
                    <span class="ayurhq-agni-legend-gray">tikshna</span>
                  </div>
                </div>
              </div>
 
              {%- if explainer.description != blank -%}
                <p class="ayurhq-article-explainer__desc">{{ explainer.description | newline_to_br }}</p>
              {%- endif -%}
            </section>
          {%- else -%}
            <section class="ayurhq-article-explainer">
              {%- if explainer.eyebrow != blank -%}
                <span class="ayurhq-article-explainer__eyebrow">{{ explainer.eyebrow }}</span>
              {%- endif -%}
              {%- if explainer.heading != blank -%}
                <h2 class="ayurhq-article-explainer__heading">{{ explainer.heading }}</h2>
              {%- endif -%}
              {%- if explainer.image != blank -%}
                <div class="ayurhq-article-explainer__image-wrapper">
                  {{ explainer.image | image_url: width: 600 | image_tag: 
                    loading: 'lazy', 
                    class: 'ayurhq-article-explainer__image',
                    widths: '300, 450, 600, 750'
                  }}
                </div>
              {%- endif -%}
              {%- if explainer.description != blank -%}
                <p class="ayurhq-article-explainer__desc">{{ explainer.description | newline_to_br }}</p>
              {%- endif -%}
            </section>
          {%- endif -%}
        {%- endif -%}

        <!-- Main Article Content Body -->
        <article class="ayurhq-article-body">
          {{ article.content }}
        </article>

        <!-- Pull Quote Block -->
        {%- if article.metafields.custom.pull_quote != blank -%}
          <blockquote class="ayurhq-article-quote">
            <p class="ayurhq-article-quote__text">
              “{{ article.metafields.custom.pull_quote.value | newline_to_br }}”
            </p>
          </blockquote>
        {%- endif -%}

        <!-- Tip Card Section ("Try this today") -->
        {%- if article.metafields.custom.try_this_today.value != blank -%}
          <section class="ayurhq-article-tips">
            <div class="ayurhq-article-tips-card">
              <h2 class="ayurhq-article-tips__heading">Try This Today</h2>
              <div class="ayurhq-article-tips__grid">
                {%- for tip in article.metafields.custom.try_this_today.value -%}
                  {%- assign tip_val = tip.value -%}
                  <div class="ayurhq-article-tip-item">
                    <h3 class="ayurhq-article-tip-item__title">
                      <span class="ayurhq-tip-check-icon">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                          <polyline points="20 6 9 17 4 12"></polyline>
                        </svg>
                      </span>
                      {{ tip_val.title }}
                    </h3>
                    <p class="ayurhq-article-tip-item__desc">{{ tip_val.description | newline_to_br }}</p>
                  </div>
                {%- endfor -%}
              </div>
            </div>
          </section>
        {%- endif -%}

        <!-- Ingredient / Herb Cards Grid -->
        {%- if article.metafields.custom.ingredient_cards.value != blank -%}
          <section class="ayurhq-article-ingredients">
            <h2 class="ayurhq-article-ingredients__heading">Key Ingredients & Herbs</h2>
            <div class="ayurhq-article-ingredients__grid">
              {%- for herb in article.metafields.custom.ingredient_cards.value -%}
                {%- assign herb_val = herb.value -%}
                <div class="ayurhq-article-ingredient-card">
                  {%- if herb_val.image != blank -%}
                    <div class="ayurhq-article-ingredient-card__image-wrapper">
                      {{ herb_val.image | image_url: width: 160 | image_tag: 
                        loading: 'lazy', 
                        class: 'ayurhq-article-ingredient-card__image'
                      }}
                    </div>
                  {%- endif -%}
                  <div class="ayurhq-article-ingredient-card__content">
                    <div class="ayurhq-article-ingredient-card__title-row">
                      <h3 class="ayurhq-article-ingredient-card__name">{{ herb_val.name }}</h3>
                      {%- if herb_val.sanskrit_name != blank -%}
                        <p class="ayurhq-article-ingredient-card__sanskrit">{{ herb_val.sanskrit_name }}</p>
                      {%- endif -%}
                    </div>
                    <p class="ayurhq-article-ingredient-card__desc">{{ herb_val.description | newline_to_br }}</p>
                  </div>
                </div>
              {%- endfor -%}
            </div>
          </section>
        {%- endif -%}

        <!-- Words To Know Card -->
        {%- if article.metafields.custom.words_to_know.value != blank -%}
          <section class="ayurhq-article-definitions">
            <h2 class="ayurhq-article-definitions__heading">Words to Know</h2>
            <div class="ayurhq-article-definitions__grid">
              {%- for def in article.metafields.custom.words_to_know.value -%}
                {%- assign def_val = def.value -%}
                <div class="ayurhq-article-definition-item">
                  <span class="ayurhq-article-definition-item__term">{{ def_val.term }}. </span>
                  <span class="ayurhq-article-definition-item__desc">{{ def_val.definition }}</span>
                </div>
              {%- endfor -%}
            </div>
          </section>
        {%- endif -%}

        <!-- Sources Section -->
        {%- if article.metafields.custom.sources != blank -%}
          <section class="ayurhq-article-sources">
            <h3 class="ayurhq-article-sources__title">Scientific Sources & References</h3>
            <div class="ayurhq-article-sources__text">
              {{ article.metafields.custom.sources.value | newline_to_br }}
            </div>
          </section>
        {%- endif -%}

        <!-- Medical Disclaimer -->
        {%- if article.metafields.custom.medical_disclaimer != blank -%}
          <div class="ayurhq-article-disclaimer">
            {{ article.metafields.custom.medical_disclaimer.value | newline_to_br }}
          </div>
        {%- else -%}
          <div class="ayurhq-article-disclaimer">
            <strong>Disclaimer:</strong> The information provided in this article is for educational purposes only and is not intended to substitute for professional medical advice, diagnosis, or treatment. Always consult with your Ayurvedic physician or qualified healthcare provider before implementing any changes.
          </div>
        {%- endif -%}

      </div>
    </div>

    <!-- Related Articles Grid -->
    {%- assign related_articles = article.metafields.custom.related_articles.value -%}
    {%- if related_articles == blank -%}
      {% comment %} If empty, fall back to other articles from the same blog (excluding current) {% endcomment %}
      {%- assign current_id = article.id -%}
      {%- assign related_count = 0 -%}
      
      {%- capture fallback_related -%}
        {%- for blog_article in blog.articles -%}
          {%- if blog_article.id != current_id and related_count < 3 -%}
            {%- render 'ayurhq-related-article-card', article: blog_article -%}
            {%- assign related_count = related_count | plus: 1 -%}
          {%- endif -%}
        {%- endfor -%}
      {%- endcapture -%}
    {%- endif -%}

    {%- if related_articles != blank or fallback_related != blank -%}
      <section class="ayurhq-article-related">
        <h2 class="ayurhq-article-ingredients__heading">Read Next</h2>
        <div class="ayurhq-article-related__grid">
          {%- if related_articles != blank -%}
            {%- for rel_art in related_articles -%}
              {%- render 'ayurhq-related-article-card', article: rel_art -%}
            {%- endfor -%}
          {%- else -%}
            {{ fallback_related }}
          {%- endif -%}
        </div>
      </section>
    {%- endif -%}

  </div>
</div>

<!-- Floating Ask Guruji CTA -->
{%- if section.settings.show_ask_guruji and section.settings.ask_guruji_link != blank -%}
  <a href="{{ section.settings.ask_guruji_link }}" class="ayurhq-floating-guruji" aria-label="Ask Guruji">
    <span class="ayurhq-floating-guruji__icon-wrapper">
      <svg viewBox="-1 0 412 500" width="20" height="24" fill="none" stroke="currentColor" stroke-width="24" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M 205 14 C 202 80, 167 112, 149.5 150 C 127 182, 105.5 225, 105.5 278 C 105.5 322, 133 362, 156 384 C 168 393, 150 400, 125 404 C 95 402, 20 407, 12 445 C 6 466, 38 486, 88 487.5 C 138 489, 180 468, 205 426 L 205 398 C 215 388, 243.5 358, 243.5 318 C 242 286, 208 246, 205 228 C 202 246, 168 286, 166.5 318 C 166.5 358, 195 388, 205 398 L 205 426 C 230 468, 272 489, 322 487.5 C 372 486, 404 466, 398 445 C 390 407, 315 402, 285 404 C 260 400, 242 393, 254 384 C 277 362, 304.5 322, 304.5 278 C 304.5 225, 283 182, 260.5 150 C 243 112, 208 80, 205 14 Z M 126 404 C 146 414, 160 432, 170 448 M 284 404 C 264 414, 250 432, 240 448" />
      </svg>
    </span>
    <span>{{ section.settings.ask_guruji_label | default: 'Ask Guruji' }}</span>
  </a>
{%- endif -%}

<!-- Mobile Sticky CTA Button -->
{%- if article.metafields.custom.sticky_cta_label != blank and article.metafields.custom.sticky_cta_link != blank -%}
  <div class="ayurhq-mobile-sticky-cta">
    <a href="{{ article.metafields.custom.sticky_cta_link.value }}" class="ayurhq-mobile-sticky-cta__btn">
      {{ article.metafields.custom.sticky_cta_label.value }}
    </a>
  </div>
{%- endif -%}

{%- else -%}

<div class="ayurhq-article-wrapper js-fallback-article" style="display:none;">
  <div class="ayurhq-article-container">
    
    <!-- Hero Image Wrapper -->
    <div id="js-article-hero" class="ayurhq-article-hero" style="display: none;">
      <nav class="ayurhq-article-back-nav">
        <a href="" id="js-back-link-hero" class="ayurhq-article-back-pill">
          <span>← Ayurveda</span>
        </a>
      </nav>
      <div class="ayurhq-article-hero__image-wrapper">
        <img id="js-hero-image" src="" alt="" class="ayurhq-article-hero__image" loading="eager" sizes="100vw">
      </div>
    </div>
    
    <!-- No-Hero Back Nav -->
    <nav id="js-article-back-nav-no-hero" class="ayurhq-article-back-nav no-hero-image" style="display: none;">
      <a href="" id="js-back-link-no-hero" class="ayurhq-article-back-pill">
        <span>← Ayurveda</span>
      </a>
    </nav>

    <div class="ayurhq-article-layout">
      <div class="ayurhq-article-main-column">
        
        <!-- Post Header Details -->
        <header class="ayurhq-article-header">
          <span id="js-badge" class="ayurhq-article-header__badge" style="display: none;"></span>
          <h1 id="js-title" class="ayurhq-article-header__title"></h1>
          <p id="js-hindi-title" class="ayurhq-article-header__hindi" lang="hi" style="display: none;"></p>
          <p id="js-excerpt" class="ayurhq-article-header__excerpt" style="display: none;"></p>

          <div class="ayurhq-article-meta">
            <span class="ayurhq-article-meta__item">By DhyanHQ Ayurveda desk</span>
            <span class="ayurhq-article-meta__separator">•</span>
            <span id="js-read-time" class="ayurhq-article-meta__item"></span>
            <span class="ayurhq-article-meta__separator">•</span>
            <span class="ayurhq-article-meta__item ayurhq-article-meta__review-badge">
              Reviewed for tradition-faithfulness
            </span>
          </div>
        </header>

        <!-- At A Glance Section -->
        <section id="js-glance" class="ayurhq-article-glance" style="display: none;">
          <h2 class="ayurhq-article-glance__title">At a Glance</h2>
          <ul id="js-glance-list" class="ayurhq-article-glance__list"></ul>
        </section>

        <!-- Agni Card / Visual Explainer Section -->
        <section id="js-agni" class="ayurhq-article-explainer ayurhq-agni-card" style="display: none;">
          <span class="ayurhq-article-explainer__eyebrow">Agni · the digestive fire</span>
          <div class="ayurhq-agni-card-content">
            <div class="ayurhq-agni-gauge-wrapper">
              <svg class="ayurhq-agni-gauge" viewBox="0 0 200 110" width="200" height="110">
                <path d="M 20 90 A 80 80 0 0 1 70 20.72" fill="none" stroke="#2E5B93" stroke-width="12" stroke-linecap="round" />
                <path d="M 70 20.72 A 80 80 0 0 1 130 20.72" fill="none" stroke="#EADCC8" stroke-width="12" />
                <path d="M 130 20.72 A 80 80 0 0 1 180 90" fill="none" stroke="#C8521B" stroke-width="12" stroke-linecap="round" />
                <circle cx="100" cy="90" r="8" fill="#1F1E1C" />
                <line id="js-agni-needle" x1="100" y1="90" x2="100" y2="35" stroke="#1F1E1C" stroke-width="4" stroke-linecap="round" />
              </svg>
            </div>
            <div class="ayurhq-agni-legend">
              <div class="ayurhq-agni-legend-item">
                <span class="ayurhq-agni-dot" style="background-color: #2E5B93;"></span>
                <span class="ayurhq-agni-legend-bold">Low</span>
                <span class="ayurhq-agni-legend-gray">manda</span>
              </div>
              <div class="ayurhq-agni-legend-item">
                <span class="ayurhq-agni-dot" style="background-color: #EADCC8;"></span>
                <span class="ayurhq-agni-legend-bold">Balanced</span>
                <span class="ayurhq-agni-legend-gray">sama</span>
              </div>
              <div class="ayurhq-agni-legend-item">
                <span class="ayurhq-agni-dot" style="background-color: #C8521B;"></span>
                <span class="ayurhq-agni-legend-bold">Sharp</span>
                <span class="ayurhq-agni-legend-gray">tikshna</span>
              </div>
            </div>
          </div>
          <p id="js-agni-desc" class="ayurhq-article-explainer__desc"></p>
        </section>

        <!-- Main Article Content Body -->
        <div id="js-body-content" class="ayurhq-article-body"></div>

        <!-- Pull Quote Block -->
        <blockquote id="js-quote" class="ayurhq-article-quote" style="display: none;">
          <p id="js-quote-text" class="ayurhq-article-quote__text"></p>
        </blockquote>

        <!-- Tip Card Section ("Try this today") -->
        <section id="js-tips" class="ayurhq-article-tips" style="display: none;">
          <div class="ayurhq-article-tips-card">
            <h2 class="ayurhq-article-tips__heading">Try This Today</h2>
            <div id="js-tips-grid" class="ayurhq-article-tips__grid"></div>
          </div>
        </section>

        <!-- Ingredient / Herb Cards Grid -->
        <section id="js-ingredients" class="ayurhq-article-ingredients" style="display: none;">
          <h2 class="ayurhq-article-ingredients__heading">Key Ingredients & Herbs</h2>
          <div id="js-ingredients-grid" class="ayurhq-article-ingredients__grid"></div>
        </section>

        <!-- Words To Know Card -->
        <section id="js-definitions" class="ayurhq-article-definitions" style="display: none;">
          <h2 class="ayurhq-article-definitions__heading">Words to Know</h2>
          <div id="js-definitions-grid" class="ayurhq-article-definitions__grid"></div>
        </section>

        <!-- Sources Section -->
        <section id="js-sources" class="ayurhq-article-sources" style="display: none;">
          <h3 class="ayurhq-article-sources__title">Scientific Sources & References</h3>
          <div id="js-sources-text" class="ayurhq-article-sources__text"></div>
        </section>

        <!-- Medical Disclaimer -->
        <div id="js-disclaimer" class="ayurhq-article-disclaimer"></div>

      </div>
    </div>

    <!-- Related Articles Grid -->
    <section id="js-related" class="ayurhq-article-related" style="display: none;">
      <h2 class="ayurhq-article-ingredients__heading">Read Next</h2>
      <div id="js-related-grid" class="ayurhq-article-related__grid"></div>
    </section>

  </div>
</div>

<div class="ayurhq-article-404-fallback" style="display:none; text-align:center; padding: 100px 20px;">
  <h2 style="font-size: 24px; font-weight: 600; color: #1F1E1C;">Article not found</h2>
  <p style="margin: 16px 0 24px; color: #8A8275;">The link may be incorrect, or the page has been removed.</p>
  <a href="{{ blog.url | default: '/blogs/news' }}" id="js-fallback-back-btn" class="button" style="background-color: #C8521B; color: white; padding: 10px 20px; border-radius: 20px; text-decoration: none;">Back to Ayurveda</a>
</div>

<!-- Floating Ask Guruji CTA -->
{%- if section.settings.show_ask_guruji and section.settings.ask_guruji_link != blank -%}
  <a href="{{ section.settings.ask_guruji_link }}" class="ayurhq-floating-guruji" aria-label="Ask Guruji">
    <span class="ayurhq-floating-guruji__icon-wrapper">
      <svg viewBox="-1 0 412 500" width="20" height="24" fill="none" stroke="currentColor" stroke-width="24" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M 205 14 C 202 80, 167 112, 149.5 150 C 127 182, 105.5 225, 105.5 278 C 105.5 322, 133 362, 156 384 C 168 393, 150 400, 125 404 C 95 402, 20 407, 12 445 C 6 466, 38 486, 88 487.5 C 138 489, 180 468, 205 426 L 205 398 C 215 388, 243.5 358, 243.5 318 C 242 286, 208 246, 205 228 C 202 246, 168 286, 166.5 318 C 166.5 358, 195 388, 205 398 L 205 426 C 230 468, 272 489, 322 487.5 C 372 486, 404 466, 398 445 C 390 407, 315 402, 285 404 C 260 400, 242 393, 254 384 C 277 362, 304.5 322, 304.5 278 C 304.5 225, 283 182, 260.5 150 C 243 112, 208 80, 205 14 Z M 126 404 C 146 414, 160 432, 170 448 M 284 404 C 264 414, 250 432, 240 448" />
      </svg>
    </span>
    <span>{{ section.settings.ask_guruji_label | default: 'Ask Guruji' }}</span>
  </a>
{%- endif -%}

<script>
  (function() {
    const handle = window.location.pathname.split('/').filter(Boolean).pop();
    const pathParts = window.location.pathname.split('/').filter(Boolean);
    const currentBlogUrl = (pathParts[0] === 'blogs' && pathParts[1]) ? '/blogs/' + pathParts[1] : '/blogs/news';
    const jsonUrl = '{{ "article-placeholder.json" | asset_url }}'.replace('article-placeholder.json', 'article-' + handle + '.json');
    
    // Set dynamic back links
    const backLinkHero = document.getElementById('js-back-link-hero');
    const backLinkNoHero = document.getElementById('js-back-link-no-hero');
    const fallbackBackBtn = document.getElementById('js-fallback-back-btn');
    if (backLinkHero) backLinkHero.href = currentBlogUrl;
    if (backLinkNoHero) backLinkNoHero.href = currentBlogUrl;
    if (fallbackBackBtn) fallbackBackBtn.href = currentBlogUrl;

    fetch(jsonUrl)
      .then(res => {
        if (!res.ok) throw new Error("Article file not found");
        return res.json();
      })
      .then(data => {
        document.title = data.title + ' · Ayurveda · DhyanHQ';
        
        // Hero Image
        const heroEl = document.getElementById('js-article-hero');
        const noHeroEl = document.getElementById('js-article-back-nav-no-hero');
        if (data.image) {
          heroEl.style.display = 'block';
          const heroImg = document.getElementById('js-hero-image');
          heroImg.src = 'https://stage.dhyanhq.com/art/ayurveda/articles/' + data.image;
          heroImg.alt = data.title;
        } else {
          noHeroEl.style.display = 'block';
        }

        // Header fields
        const badgeEl = document.getElementById('js-badge');
        if (data.badge) {
          badgeEl.textContent = data.badge;
          badgeEl.style.display = 'inline-block';
        }
        document.getElementById('js-title').textContent = data.title;
        
        const hindiEl = document.getElementById('js-hindi-title');
        if (data.hindi_title) {
          hindiEl.textContent = data.hindi_title;
          hindiEl.style.display = 'block';
        }

        const excerptEl = document.getElementById('js-excerpt');
        if (data.excerpt) {
          excerptEl.textContent = data.excerpt;
          excerptEl.style.display = 'block';
        }

        document.getElementById('js-read-time').textContent = data.read_time;

        // At a glance
        const glanceEl = document.getElementById('js-glance');
        const glanceList = document.getElementById('js-glance-list');
        if (data.at_a_glance && data.at_a_glance.length > 0) {
          glanceEl.style.display = 'block';
          glanceList.innerHTML = data.at_a_glance.map(item => `
            <li class="flex gap-2.5 text-[14.5px] leading-relaxed text-ink-v4">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="mt-[3px] flex-shrink-0 text-bhagwa" aria-hidden="true">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
              <span>${item}</span>
            </li>
          `).join('');
        }

        // Agni Card
        if (data.has_agni) {
          document.getElementById('js-agni').style.display = 'block';
          document.getElementById('js-agni-desc').textContent = data.agni_desc || '';
          
          // Adjust needle if low or sharp
          const needle = document.getElementById('js-agni-needle');
          const titleLower = data.title.toLowerCase();
          if (titleLower.includes('low') || titleLower.includes('constipation') || titleLower.includes('heavy') || titleLower.includes('sluggish') || titleLower.includes('slow')) {
            needle.setAttribute('x2', '60');
            needle.setAttribute('y2', '55');
          } else if (titleLower.includes('sharp') || titleLower.includes('acidity') || titleLower.includes('heartburn') || titleLower.includes('burn')) {
            needle.setAttribute('x2', '140');
            needle.setAttribute('y2', '55');
          }
        }

        // Body Sections
        const bodyContent = document.getElementById('js-body-content');
        if (data.body && data.body.length > 0) {
          bodyContent.innerHTML = data.body.map((sec, sIdx) => {
            let secHtml = '';
            if (sec.heading) {
              secHtml += `<h2 class="mb-2 text-[20px] font-semibold leading-snug md:text-[22px]">${sec.heading}</h2>`;
            }
            if (sec.paragraphs && sec.paragraphs.length > 0) {
              secHtml += `<div class="space-y-4">` + sec.paragraphs.map((p, pIdx) => {
                // Apply drop-cap styling if it's the very first paragraph of the body
                if (sIdx === 0 && pIdx === 0 && p.length > 3) {
                  const firstChar = p.charAt(0);
                  const restStr = p.slice(1);
                  return `
                    <p class="text-[16px] leading-[1.78] text-ink-v4/90 md:text-[17.5px]">
                      <span class="float-left mr-2 mt-1 font-display text-[52px] font-semibold leading-[0.8] text-bhagwa">${firstChar}</span>${restStr}
                    </p>
                  `;
                }
                return `<p class="text-[16px] leading-[1.78] text-ink-v4/90 md:text-[17.5px]">${p}</p>`;
              }).join('') + `</div>`;
            }
            if (sec.pullQuote) {
              secHtml += `
                <blockquote class="my-6 border-l-[3px] border-bhagwa pl-5 text-[20px] font-medium italic leading-snug text-ink-v4 md:text-[24px]">
                  “${sec.pullQuote}”
                </blockquote>
              `;
            }
            return `<section>${secHtml}</section>`;
          }).join('<div style="height:28px;"></div>');
        }

        // Try this today
        const tipsEl = document.getElementById('js-tips');
        const tipsGrid = document.getElementById('js-tips-grid');
        if (data.try_this_today && data.try_this_today.length > 0) {
          tipsEl.style.display = 'block';
          tipsGrid.innerHTML = data.try_this_today.map(tip => `
            <div class="flex gap-2.5">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="mt-[2px] flex-shrink-0 text-bhagwa" aria-hidden="true">
                <circle cx="12" cy="12" r="9"></circle>
                <polyline points="8.5 12 11 14.5 15.5 9.5"></polyline>
              </svg>
              <div>
                <div class="text-[14.5px] font-semibold text-ink-v4">${tip.title}</div>
                <div class="text-[13.5px] leading-relaxed text-mute-v4">${tip.description}</div>
              </div>
            </div>
          `).join('');
        }

        // Key ingredients
        const ingredientsEl = document.getElementById('js-ingredients');
        const ingredientsGrid = document.getElementById('js-ingredients-grid');
        if (data.ingredients && data.ingredients.length > 0) {
          ingredientsEl.style.display = 'block';
          ingredientsGrid.innerHTML = data.ingredients.map(herb => `
            <div class="ayurhq-article-ingredient-card">
              ${herb.image ? `
                <div class="ayurhq-article-ingredient-card__image-wrapper">
                  <img src="https://stage.dhyanhq.com/art/ayurveda/herbs/${herb.image}" alt="${herb.name}" class="ayurhq-article-ingredient-card__image" width="80" height="80">
                </div>
              ` : ''}
              <div class="ayurhq-article-ingredient-card__content">
                <div class="ayurhq-article-ingredient-card__title-row">
                  <h3 class="ayurhq-article-ingredient-card__name">${herb.name}</h3>
                  ${herb.sanskrit ? `<p class="ayurhq-article-ingredient-card__sanskrit" lang="hi">${herb.sanskrit}</p>` : ''}
                </div>
                <p class="ayurhq-article-ingredient-card__desc">${herb.description}</p>
              </div>
            </div>
          `).join('');
        }

        // Words to know
        const definitionsEl = document.getElementById('js-definitions');
        const definitionsGrid = document.getElementById('js-definitions-grid');
        if (data.words_to_know && data.words_to_know.length > 0) {
          definitionsEl.style.display = 'block';
          definitionsGrid.innerHTML = data.words_to_know.map(word => `
            <div class="text-[13.5px] leading-relaxed">
              <span class="font-semibold text-bhagwa">${word.term} </span>
              <span class="text-mute-v4">${word.definition}</span>
            </div>
          `).join('');
        }

        // Sources
        const sourcesEl = document.getElementById('js-sources');
        const sourcesText = document.getElementById('js-sources-text');
        if (data.sources) {
          sourcesEl.style.display = 'block';
          sourcesText.textContent = data.sources;
        }

        // Disclaimer
        document.getElementById('js-disclaimer').textContent = data.disclaimer;

        // Related articles
        const relatedEl = document.getElementById('js-related');
        const relatedGrid = document.getElementById('js-related-grid');
        relatedEl.style.display = 'block';
        
        const fallbackRelated = [
          {
            title: "Acidity and heartburn",
            handle: "acidity-heartburn",
            image: "acidity-heartburn.webp",
            excerpt: "A calm, plain-language look at why acidity and heartburn happen, what Ayurveda sees behind that burning feeling, and a few everyday habits.",
            read_time: "5 min read"
          },
          {
            title: "Gas and bloating",
            handle: "gas-and-bloating",
            image: "gas-and-bloating.webp",
            excerpt: "A plain-language look at how Ayurveda understands gas and bloating, and the simple daily habits the old texts suggest.",
            read_time: "4 min read"
          },
          {
            title: "Easing constipation",
            handle: "constipation-relief",
            image: "constipation-relief.webp",
            excerpt: "What Ayurveda sees behind constipation, and gentle everyday habits around food, routine, and calm that the tradition suggests.",
            read_time: "5 min read"
          }
        ].filter(item => item.handle !== handle).slice(0, 3);

        relatedGrid.innerHTML = fallbackRelated.map(rel => `
          <a href="${currentBlogUrl}/${rel.handle}" class="ayurhq-topic-article-card group">
            <div class="ayurhq-topic-article-card__image-wrapper">
              <img src="https://stage.dhyanhq.com/art/ayurveda/articles/${rel.image}" alt="${rel.title}" class="ayurhq-topic-article-card__image" loading="lazy" width="300" height="200">
              <div class="ayurhq-topic-article-card__accent-line"></div>
            </div>
            <div class="ayurhq-topic-article-card__info">
              <h2 class="ayurhq-topic-article-card__title">${rel.title}</h2>
              <p class="ayurhq-topic-article-card__excerpt">${rel.excerpt}</p>
              <div class="ayurhq-topic-article-card__read-time">${rel.read_time}</div>
            </div>
          </a>
        `).join('');

        // Show the wrapper
        document.querySelector('.js-fallback-article').style.display = 'block';
      })
      .catch(err => {
        console.error(err);
        document.querySelector('.ayurhq-article-404-fallback').style.display = 'block';
      });
  })();
</script>

{%- endif -%}

{% schema %}
{
  "name": "AyurHQ Article Template",
  "settings": [
    {
      "type": "header",
      "content": "Floating CTA Settings"
    },
    {
      "type": "checkbox",
      "id": "show_ask_guruji",
      "label": "Show Floating Ask Guruji Button",
      "default": true
    },
    {
      "type": "text",
      "id": "ask_guruji_label",
      "label": "Button Label",
      "default": "Ask Guruji"
    },
    {
      "type": "url",
      "id": "ask_guruji_link",
      "label": "Button Link",
      "info": "Link to consultation page or chat."
    }
  ]
}
{% endschema %}
