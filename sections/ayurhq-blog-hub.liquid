                <p class="ayurhq-consultation-step__desc">{{ step3_desc }}</p>
              </div>
            </div>
          </div>
        </div>
      </div>
      <p class="ayurhq-consultation-disclaimer">{{ consult_disclaimer }}</p>
    </div>
  </section>

  {%- endif -%}
</div>

