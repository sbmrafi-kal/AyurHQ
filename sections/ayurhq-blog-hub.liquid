{{ 'ayurhq-blog-hub.css' | asset_url | stylesheet_tag }}

<div class="ayurhq-blog-wrapper">
  
  <!-- Hero Banner -->
  <header class="ayurhq-blog-hero">
    <div class="ayurhq-blog-hero-container">
      {%- if blog.metafields.custom.hero_eyebrow != blank -%}
        <span class="ayurhq-blog-hero__eyebrow">{{ blog.metafields.custom.hero_eyebrow.value }}</span>
      {%- else -%}
        <span class="ayurhq-blog-hero__eyebrow">AYURVEDA INSIDE THE ASHRAM</span>
      {%- endif -%}

      <h1 class="ayurhq-blog-hero__heading">
        {{ blog.metafields.custom.hero_heading.value | default: "आयुर्वेद · daily care for the body you practice with" }}
      </h1>

      {%- if blog.metafields.custom.hero_subheading != blank -%}
        <p class="ayurhq-blog-hero__subheading">{{ blog.metafields.custom.hero_subheading.value | newline_to_br }}</p>
      {%- else -%}
        <p class="ayurhq-blog-hero__subheading">Food, sleep, movement and seasonal routine brought into the same calm rhythm as your yoga and meditation.</p>
      {%- endif -%}

      <div class="ayurhq-blog-hero__actions">
        {%- if blog.metafields.custom.primary_cta_label != blank and blog.metafields.custom.primary_cta_link != blank -%}
          <a href="{{ blog.metafields.custom.primary_cta_link.value }}" class="ayurhq-blog-btn">
            {{ blog.metafields.custom.primary_cta_label.value }}
          </a>
        {%- else -%}
          <a href="#guides" class="ayurhq-blog-btn">Browse topics</a>
        {%- endif -%}
      </div>

      <div class="ayurhq-blog-hero__stats">
        {%- if blog.metafields.custom.topic_count_label != blank -%}
          <span class="ayurhq-blog-hero__pill"><span class="ayurhq-blog-hero__pill-dot"></span>{{ blog.metafields.custom.topic_count_label.value }}</span>
        {%- else -%}
          <span class="ayurhq-blog-hero__pill"><span class="ayurhq-blog-hero__pill-dot"></span>Topics <strong>18</strong></span>
        {%- endif -%}
        {%- if blog.metafields.custom.read_count_label != blank -%}
          <span class="ayurhq-blog-hero__pill"><span class="ayurhq-blog-hero__pill-dot"></span>{{ blog.metafields.custom.read_count_label.value }}</span>
        {%- else -%}
          <span class="ayurhq-blog-hero__pill"><span class="ayurhq-blog-hero__pill-dot"></span>Reads <strong>250</strong></span>
        {%- endif -%}
      </div>
    </div>
  </header>

  <!-- Care Paths Section -->
  {%- if section.settings.show_care_paths -%}
    <section class="ayurhq-blog-care-paths-section">
      <div class="ayurhq-blog-container">
        <div class="ayurhq-blog-editorial">
          <div class="ayurhq-blog-editorial__teaser">
            <span class="ayurhq-blog-editorial__teaser-eyebrow">{{ section.settings.care_paths_eyebrow }}</span>
            <h2 class="ayurhq-blog-editorial__teaser-heading">{{ section.settings.care_paths_heading }}</h2>
            <p class="ayurhq-blog-editorial__teaser-text">{{ section.settings.care_paths_text }}</p>
          </div>

          <div class="ayurhq-blog-editorial__list" aria-label="Care paths">
            <article class="ayurhq-blog-editorial__row">
              <div class="ayurhq-blog-editorial__row-body">
                <h3 class="ayurhq-blog-editorial__row-title">{{ section.settings.path1_title }}</h3>
                <p class="ayurhq-blog-editorial__row-text">{{ section.settings.path1_desc }}</p>
              </div>
              <div class="ayurhq-blog-editorial__row-label">{{ section.settings.path1_tags }}</div>
              {%- if section.settings.path1_link != blank -%}
                <a href="{{ section.settings.path1_link }}" class="ayurhq-blog-editorial__row-link">
                  {{ section.settings.path1_label | default: 'Begin with asana' }}
                </a>
              {%- endif -%}
            </article>

            <article class="ayurhq-blog-editorial__row">
              <div class="ayurhq-blog-editorial__row-body">
                <h3 class="ayurhq-blog-editorial__row-title">{{ section.settings.path2_title }}</h3>
                <p class="ayurhq-blog-editorial__row-text">{{ section.settings.path2_desc }}</p>
              </div>
              <div class="ayurhq-blog-editorial__row-label">{{ section.settings.path2_tags }}</div>
              {%- if section.settings.path2_link != blank -%}
                <a href="{{ section.settings.path2_link }}" class="ayurhq-blog-editorial__row-link">
                  {{ section.settings.path2_label | default: 'Go to yoga nidra' }}
                </a>
              {%- endif -%}
            </article>

            <article class="ayurhq-blog-editorial__row">
              <div class="ayurhq-blog-editorial__row-body">
                <h3 class="ayurhq-blog-editorial__row-title">{{ section.settings.path3_title }}</h3>
                <p class="ayurhq-blog-editorial__row-text">{{ section.settings.path3_desc }}</p>
              </div>
              <div class="ayurhq-blog-editorial__row-label">{{ section.settings.path3_tags }}</div>
              {%- if section.settings.path3_link != blank -%}
                <a href="{{ section.settings.path3_link }}" class="ayurhq-blog-editorial__row-link">
                  {{ section.settings.path3_label | default: 'Start with breath' }}
                </a>
              {%- endif -%}
            </article>

            <article class="ayurhq-blog-editorial__row">
              <div class="ayurhq-blog-editorial__row-body">
                <h3 class="ayurhq-blog-editorial__row-title">{{ section.settings.path4_title }}</h3>
                <p class="ayurhq-blog-editorial__row-text">{{ section.settings.path4_desc }}</p>
              </div>
              <div class="ayurhq-blog-editorial__row-label">{{ section.settings.path4_tags }}</div>
              {%- if section.settings.path4_link != blank -%}
                <a href="{{ section.settings.path4_link }}" class="ayurhq-blog-editorial__row-link">
                  {{ section.settings.path4_label | default: 'See the day rhythm' }}
                </a>
              {%- else -%}
                <a href="#" class="ayurhq-blog-editorial__row-link">
                  {{ section.settings.path4_label | default: 'See the day rhythm' }}
                </a>
              {%- endif -%}
            </article>
          </div>
        </div>
      </div>
    </section>
  {%- endif -%}

  <!-- Daily Rhythm Section -->
  {%- if section.settings.show_daily_rhythm -%}
    <section class="ayurhq-blog-daily-rhythm-section">
      <div class="ayurhq-blog-container">
        <div class="ayurhq-daily-rhythm-grid">
          <div class="ayurhq-daily-rhythm-teaser">
            <span class="ayurhq-daily-rhythm-teaser__eyebrow">{{ section.settings.daily_rhythm_eyebrow }}</span>
            <h2 class="ayurhq-daily-rhythm-teaser__heading">{{ section.settings.daily_rhythm_heading }}</h2>
            <p class="ayurhq-daily-rhythm-teaser__text">{{ section.settings.daily_rhythm_text }}</p>
          </div>

          <div class="ayurhq-daily-rhythm-list" aria-label="Daily rhythm">
            {%- for i in (1..4) -%}
              {%- assign rhythm_label_key = 'rhythm' | append: i | append: '_label' -%}
              {%- assign rhythm_title_key = 'rhythm' | append: i | append: '_title' -%}
              {%- assign rhythm_desc_key = 'rhythm' | append: i | append: '_desc' -%}
              
              {%- assign rhythm_label = section.settings[rhythm_label_key] -%}
              {%- assign rhythm_title = section.settings[rhythm_title_key] -%}
              {%- assign rhythm_desc = section.settings[rhythm_desc_key] -%}

              {%- if rhythm_title != blank -%}
                <div class="ayurhq-daily-rhythm-item">
                  <div class="ayurhq-daily-rhythm-item__meta">
                    <span class="ayurhq-daily-rhythm-item__tags">{{ rhythm_label }}</span>
                  </div>
                  <div class="ayurhq-daily-rhythm-item__content">
                    <h3 class="ayurhq-daily-rhythm-item__title">{{ rhythm_title }}</h3>
                    <p class="ayurhq-daily-rhythm-item__desc">{{ rhythm_desc }}</p>
                  </div>
                </div>
              {%- endif -%}
            {%- endfor -%}
          </div>
        </div>
      </div>
    </section>
  {%- endif -%}

  <!-- Featured Article Section -->
  <section class="ayurhq-blog-featured-section">
    <div class="ayurhq-blog-container">
      <div class="ayurhq-section-header">
        <span class="ayurhq-section-eyebrow">READ · पढ़ें</span>
        <h2 class="ayurhq-blog-section-title">Everyday Ayurveda, explained simply</h2>
      </div>

      {%- assign featured_article = blog.metafields.custom.featured_article.value -%}
      {%- if featured_article != blank -%}
        <div class="ayurhq-blog-featured-card">
          <div class="ayurhq-blog-featured-card__image-wrapper">
            {%- if featured_article.image != blank -%}
              {{ featured_article.image | image_url: width: 1000 | image_tag: 
                loading: 'lazy', 
                class: 'ayurhq-blog-featured-card__image' 
              }}
            {%- endif -%}
          </div>
          <div class="ayurhq-blog-featured-card__content">
            <div class="ayurhq-blog-featured-card__meta">
              <span class="ayurhq-blog-featured-card__badge">FEATURED</span>
              {%- if featured_article.metafields.custom.read_time != blank -%}
                <span class="ayurhq-blog-featured-card__read-time">• {{ featured_article.metafields.custom.read_time.value }} read</span>
              {%- endif -%}
            </div>
            <h3 class="ayurhq-blog-featured-card__title">{{ featured_article.title }}</h3>
            {%- if featured_article.metafields.custom.hindi_title != blank -%}
              <p class="ayurhq-blog-article-card__hindi-title">{{ featured_article.metafields.custom.hindi_title.value }}</p>
            {%- endif -%}
            <p class="ayurhq-blog-featured-card__excerpt">
              {{ featured_article.excerpt | default: featured_article.content | strip_html | truncatewords: 30 }}
            </p>
            <a href="{{ featured_article.url }}" class="ayurhq-blog-featured-card__cta">
              Read this first &rarr;
            </a>
          </div>
        </div>
      {%- else -%}
        {% comment %} Fallback Featured Card {% endcomment %}
        <div class="ayurhq-blog-featured-card">
          <div class="ayurhq-blog-featured-card__image-wrapper">
            <img src="{{ 'ayurhq-featured-acidity.webp' | asset_url }}" alt="Acidity and heartburn" class="ayurhq-blog-featured-card__image" loading="lazy" width="800" height="600">
          </div>
          <div class="ayurhq-blog-featured-card__content">
            <div class="ayurhq-blog-featured-card__meta">
              <span class="ayurhq-blog-featured-card__badge">FEATURED</span>
              <span class="ayurhq-blog-featured-card__read-time">• 4 min read</span>
            </div>
            <h3 class="ayurhq-blog-featured-card__title">Acidity and heartburn</h3>
            <p class="ayurhq-blog-article-card__hindi-title">अम्लता और छाती में जलन</p>
            <p class="ayurhq-blog-featured-card__excerpt">
              A calm, plain-language look at why acidity and heartburn happen, what Ayurveda sees behind that burning feeling, and a few everyday habits the tradition suggests you can start today.
            </p>
            <a href="/blogs/ayurveda/acidity-and-heartburn" class="ayurhq-blog-featured-card__cta">
              Read this first &rarr;
            </a>
          </div>
        </div>
      {%- endif -%}
    </div>
  </section>

  <!-- Topic Shelf Section -->
  <section class="ayurhq-blog-topics-section">
    <div class="ayurhq-blog-container">
      <div class="ayurhq-section-header">
        <span class="ayurhq-section-eyebrow">BROWSE · विषय</span>
        <h2 class="ayurhq-blog-section-title">Find your topic</h2>
        <p class="ayurhq-section-subheading">The full library, sorted into shelves you can actually navigate. {{ blog.articles_count | default: 250 }} articles</p>
      </div>

      <div class="ayurhq-blog-topic-grid">
        {%- assign topic_cards = blog.metafields.custom.topic_cards.value -%}
        {%- if topic_cards != blank -%}
          {%- for topic_card in topic_cards -%}
            {%- render 'ayurhq-topic-card', topic_card: topic_card -%}
          {%- endfor -%}
        {%- else -%}
          {% comment %} Fallback hardcoded topic grid of 18 categories – pipe-delimited to avoid splitting entries that contain commas {% endcomment %}
          {%- assign fallback_titles_str = "Digestion & gut|Food & kitchen|Herbs & remedies|Weight & cravings|Immunity|Seasons & routine|Sleep & energy|Mind & calm|Daily habits|Joints & body|Skin & glow|Hair & scalp|Eyes, ears & mouth|Women's wellbeing|Men's wellbeing|Children's care|Elder care|Ayurveda basics" -%}
          {%- assign fallback_titles = fallback_titles_str | split: "|" -%}
          {%- assign fallback_hindis_str = "पाचन|आहार|औषधि|वजन और लालच|रोग-प्रतिरोध|ऋतुचर्या|नींद और ऊर्जा|मन और शांति|दिनचर्या|जोड़ और शरीर|त्वचा|बाल|आँख, कान, मुँह|स्त्री-स्वास्थ्य|पुरुष-स्वास्थ्य|बच्चों की देखभाल|बुजुर्गों की देखभाल|आयुर्वेद की बुनियाद" -%}
          {%- assign fallback_hindis = fallback_hindis_str | split: "|" -%}
          {%- assign fallback_counts = "24|16|10|13|15|11|14|14|16|17|16|11|11|13|9|13|11|16" | split: "|" -%}
          {%- assign fallback_handles = "digestion|food|herbs|weight|immunity|seasons|sleep|mind|habits|joints|skin|hair|eyes|womens|mens|children|elder|basics" | split: "|" -%}

          {%- for fallback_title in fallback_titles -%}
            {%- assign idx = forloop.index -%}
            {%- assign fallback_hindi = fallback_hindis[forloop.index0] -%}
            {%- assign fallback_count = fallback_counts[forloop.index0] -%}
            {%- assign fallback_handle = fallback_handles[forloop.index0] -%}
            
            <a href="/blogs/ayurveda/topic/{{ fallback_handle }}" class="ayurhq-blog-topic-card">
              <div class="ayurhq-blog-topic-card__image-wrapper">
                {%- assign image_filename = 'ayurhq-topic-' | append: fallback_handle | append: '.webp' -%}
                <img src="{{ image_filename | asset_url }}" alt="{{ fallback_title }}" class="ayurhq-blog-topic-card__image" loading="lazy" width="300" height="200">
              </div>
              <div class="ayurhq-blog-topic-card__content">
                <h3 class="ayurhq-blog-topic-card__title">{{ fallback_title }}</h3>
                <div class="ayurhq-blog-topic-card__footer">
                  <span class="ayurhq-blog-topic-card__hindi">{{ fallback_hindi }}</span>
                  <span class="ayurhq-blog-topic-card__count">{{ fallback_count }}</span>
                </div>
              </div>
            </a>
          {%- endfor -%}
        {%- endif -%}
      </div>
    </div>
  </section>

  <!-- Vaidya Consult CTA Section -->
  {%- assign consult_heading = blog.metafields.custom.consultation_heading.value | default: "Book a consultation with a vaidya" -%}
  {%- assign consult_text = blog.metafields.custom.consultation_text.value | default: "When personal guidance is needed, the intake stays simple and the plan returns to your daily rhythm instead of becoming another disconnected PDF." -%}
  {%- assign consult_label = blog.metafields.custom.consultation_cta_label.value | default: "WhatsApp consults opening soon" -%}
  {%- assign consult_link = blog.metafields.custom.consultation_cta_link.value | default: "#" -%}

  <section class="ayurhq-blog-consultation-section">
    <div class="ayurhq-blog-container">
      <div class="ayurhq-blog-consultation">
        <div class="ayurhq-blog-consultation-container">
          <div class="ayurhq-blog-consultation__left">
            <span class="ayurhq-blog-consultation__eyebrow">VAIDYA CONSULT</span>
            <h2 class="ayurhq-blog-consultation__heading">{{ consult_heading }}</h2>
            <p class="ayurhq-blog-consultation__text">{{ consult_text }}</p>
            <a href="{{ consult_link }}" class="ayurhq-consultation-btn">{{ consult_label }}</a>
          </div>

          <div class="ayurhq-blog-consultation__right">
            <div class="ayurhq-consultation-step">
              <span class="ayurhq-consultation-step__num">01</span>
              <div class="ayurhq-consultation-step__content">
                <h3 class="ayurhq-consultation-step__title">Share the pattern</h3>
                <p class="ayurhq-consultation-step__desc">Sleep, appetite, digestion, pain, energy and current routine.</p>
              </div>
            </div>
            <div class="ayurhq-consultation-step">
              <span class="ayurhq-consultation-step__num">02</span>
              <div class="ayurhq-consultation-step__content">
                <h3 class="ayurhq-consultation-step__title">Receive a small plan</h3>
                <p class="ayurhq-consultation-step__desc">Food timing, practice adjustments and one or two daily changes.</p>
              </div>
            </div>
            <div class="ayurhq-consultation-step">
              <span class="ayurhq-consultation-step__num">03</span>
              <div class="ayurhq-consultation-step__content">
                <h3 class="ayurhq-consultation-step__title">Fold it into Today</h3>
                <p class="ayurhq-consultation-step__desc">The plan points back to classes, breath and quiet reminders already inside DhyanHQ.</p>
              </div>
            </div>
          </div>
        </div>
        <p class="ayurhq-consultation-disclaimer">
          Ayurveda guidance on DhyanHQ is supportive care, not emergency or diagnostic medical treatment.
        </p>
      </div>
    </div>
  </section>
</div>

<!-- Floating Ask Guruji CTA -->
{%- if section.settings.show_ask_guruji and section.settings.ask_guruji_link != blank -%}
  <a href="{{ section.settings.ask_guruji_link }}" class="ayurhq-floating-guruji" aria-label="Ask Guruji">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M12 3c-1.5 3.5-2.5 5.5-5 7 2.5.5 4.5-1 5-3.5.5 2.5 2.5 4 5 3.5-2.5-1.5-3.5-3.5-5-7z" />
      <path d="M12 7c-3.5 3-6.5 3-8 3.5 3.5 1.5 6.5.5 8-3.5z" />
      <path d="M12 7c3.5 3 6.5 3 8 3.5-3.5 1.5-6.5.5-8-3.5z" />
      <path d="M5 14c1 1.5 3 2.5 7 2.5s6-1 7-2.5" />
    </svg>
    <span>{{ section.settings.ask_guruji_label | default: 'Ask Guruji' }}</span>
  </a>
{%- endif -%}

{% schema %}
{
  "name": "AyurHQ Ayurveda Blog Hub",
  "settings": [
    {
      "type": "header",
      "content": "Care Paths Settings"
    },
    {
      "type": "checkbox",
      "id": "show_care_paths",
      "label": "Show Care Paths Section",
      "default": true
    },
    {
      "type": "text",
      "id": "care_paths_eyebrow",
      "label": "Care Paths Eyebrow",
      "default": "CARE PATHS"
    },
    {
      "type": "text",
      "id": "care_paths_heading",
      "label": "Care Paths Heading",
      "default": "Start with what the body is saying"
    },
    {
      "type": "textarea",
      "id": "care_paths_text",
      "label": "Care Paths Description",
      "default": "Each path points to practice you can begin today, then deepens into food, rest and routine guidance."
    },
    {
      "type": "header",
      "content": "Daily Rhythm Settings"
    },
    {
      "type": "checkbox",
      "id": "show_daily_rhythm",
      "label": "Show Daily Rhythm Section",
      "default": true
    },
    {
      "type": "text",
      "id": "daily_rhythm_eyebrow",
      "label": "Daily Rhythm Eyebrow",
      "default": "DAILY RHYTHM"
    },
    {
      "type": "text",
      "id": "daily_rhythm_heading",
      "label": "Daily Rhythm Heading",
      "default": "Care before symptoms get loud"
    },
    {
      "type": "textarea",
      "id": "daily_rhythm_text",
      "label": "Daily Rhythm Description",
      "default": "The Ayurveda tab is not a separate clinic shelf. It sits inside the ashram day: wake, eat, move, rest."
    },
    {
      "type": "header",
      "content": "Daily Rhythm - Step 1"
    },
    {
      "type": "text",
      "id": "rhythm1_label",
      "label": "Step 1 Label",
      "default": "MORNING"
    },
    {
      "type": "text",
      "id": "rhythm1_title",
      "label": "Step 1 Title",
      "default": "Warm water, light movement, steady breath"
    },
    {
      "type": "textarea",
      "id": "rhythm1_desc",
      "label": "Step 1 Description",
      "default": "Begin with a simple reset before the first class, especially on heavy or stiff mornings."
    },
    {
      "type": "header",
      "content": "Daily Rhythm - Step 2"
    },
    {
      "type": "text",
      "id": "rhythm2_label",
      "label": "Step 2 Label",
      "default": "MIDDAY"
    },
    {
      "type": "text",
      "id": "rhythm2_title",
      "label": "Step 2 Title",
      "default": "Make lunch the main meal"
    },
    {
      "type": "textarea",
      "id": "rhythm2_desc",
      "label": "Step 2 Description",
      "default": "Keep the strongest digestion window clean and unhurried; the rest of the day gets easier."
    },
    {
      "type": "header",
      "content": "Daily Rhythm - Step 3"
    },
    {
      "type": "text",
      "id": "rhythm3_label",
      "label": "Step 3 Label",
      "default": "EVENING"
    },
    {
      "type": "text",
      "id": "rhythm3_title",
      "label": "Step 3 Title",
      "default": "Lower stimulation before practice"
    },
    {
      "type": "textarea",
      "id": "rhythm3_desc",
      "label": "Step 3 Description",
      "default": "Move from work into breath, chanting or yoga nidra instead of carrying the whole day into sleep."
    },
    {
      "type": "header",
      "content": "Daily Rhythm - Step 4"
    },
    {
      "type": "text",
      "id": "rhythm4_label",
      "label": "Step 4 Label",
      "default": "WEEKLY"
    },
    {
      "type": "text",
      "id": "rhythm4_title",
      "label": "Step 4 Title",
      "default": "Notice one pattern, not ten"
    },
    {
      "type": "textarea",
      "id": "rhythm4_desc",
      "label": "Step 4 Description",
      "default": "Track the clearest signal: sleep, stool, hunger, pain or energy. Guidance becomes useful when it is specific."
    },
    {
      "type": "header",
      "content": "Path 1: Joints"
    },
    {
      "type": "text",
      "id": "path1_title",
      "label": "Path 1 Title",
      "default": "Joints, knees and back"
    },
    {
