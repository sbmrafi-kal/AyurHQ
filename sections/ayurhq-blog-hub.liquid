  <script>
    (function() {
      const path = window.location.pathname.toLowerCase();
      if (path.includes('/tagged/') || path.includes('/tag/')) {
        const parts = path.split('/');
        let tagIndex = parts.indexOf('tagged');
        if (tagIndex === -1) tagIndex = parts.indexOf('tag');
        
        const tagHandle = tagIndex !== -1 && parts[tagIndex + 1] ? parts[tagIndex + 1] : '';
        
        // Normalize tag handle to match the keys of window.AYURHQ_FALLBACK_TOPICS
        let normalizedTag = tagHandle;
        const mappings = {
          'digestion-gut': 'digestion',
          'food-kitchen': 'food',
          'herbs-remedies': 'herbs',
          'weight-cravings': 'weight',
          'seasons-routine': 'seasons',
          'sleep-energy': 'sleep',
          'mind-calm': 'mind',
          'daily-habits': 'habits',
          'joints-body': 'joints',
          'skin-glow': 'skin',
          'hair-scalp': 'hair',
          'eyes-ears-mouth': 'eyes',
          'womens-wellbeing': 'womens',
          'mens-wellbeing': 'mens',
          'childrens-care': 'children',
          'elder-care': 'elder',
          'ayurveda-basics': 'basics'
        };
        if (mappings[normalizedTag]) {
          normalizedTag = mappings[normalizedTag];
        }

        if (normalizedTag && window.AYURHQ_FALLBACK_TOPICS && window.AYURHQ_FALLBACK_TOPICS[normalizedTag]) {
          const data = window.AYURHQ_FALLBACK_TOPICS[normalizedTag];
          
          // Set dynamic browser tab title
          document.title = data.title + ' · Ayurveda · DhyanHQ';
          
          // Hide normal content, show fallback
          const normalContent = document.getElementById('js-ayurhq-normal-blog-content');
          if (normalContent) normalContent.style.display = 'none';
          
          const fallbackPage = document.getElementById('js-ayurhq-fallback-topic-page');
          if (fallbackPage) fallbackPage.style.display = 'block';
          
          // Set back link
          const backBtn = document.getElementById('js-fallback-topic-back-btn');
          const currentBlogUrl = '{{ current_blog_url }}';
          if (backBtn) backBtn.href = currentBlogUrl + '#guides';
          
          // Set title and hindi title
          document.getElementById('js-fallback-topic-title').textContent = data.title;
          const hindiEl = document.getElementById('js-fallback-topic-hindi');
          if (data.hindi) {
            hindiEl.textContent = data.hindi;
            hindiEl.style.display = 'inline';
          } else {
            hindiEl.style.display = 'none';
          }
          
          // Set count
          document.getElementById('js-fallback-topic-count').textContent = data.count + ' articles';
          
          // Build cards
          const grid = document.getElementById('js-fallback-topic-grid');
          if (grid && data.titles) {
            const arrTitles = data.titles.split('|');
            const arrExcerpts = data.excerpts.split('|');
            const arrTimes = data.times.split('|');
            const arrHandles = data.handles.split('|');
            const arrImages = data.images.split('|');
            
            let html = '';
            for (let i = 0; i < arrTitles.length; i++) {
              if (!arrTitles[i]) continue;
              const title = arrTitles[i];
              const excerpt = arrExcerpts[i] || '';
              const readTime = arrTimes[i] || '';
              const handle = arrHandles[i] || '';
              const img = arrImages[i] || '';
              
              const imgUrl = img ? 'https://stage.dhyanhq.com/art/ayurveda/articles/' + img : '';
              
              html += `
                <a href="${currentBlogUrl}/${handle}" class="ayurhq-topic-article-card group">
                  <div class="ayurhq-topic-article-card__image-wrapper">
                    ${imgUrl ? `
                      <img src="${imgUrl}" alt="${title}" class="ayurhq-topic-article-card__image" loading="lazy" width="300" height="200">
                    ` : `
                      <div class="ayurhq-topic-article-card__placeholder"></div>
                    `}
                    <div class="ayurhq-topic-article-card__accent-line"></div>
                  </div>
                  <div class="ayurhq-topic-article-card__info">
                    <h2 class="ayurhq-topic-article-card__title">${title}</h2>
                    <p class="ayurhq-topic-article-card__excerpt">${excerpt}</p>
                    ${readTime ? `<div class="ayurhq-topic-article-card__read-time">${readTime}</div>` : ''}
                  </div>
                </a>
              `;
            }
            grid.innerHTML = html;
          }
        }
      }
    })();
  </script>


