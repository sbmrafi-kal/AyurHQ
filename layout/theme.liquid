                  </span>
                </a>
              </li>
            `;

            // Highlight active tab
            desktopMenu.querySelectorAll('a').forEach(function(el) {
              el.classList.remove('menu-list__link--active');
            });
            if (path.includes('/today')) {
              desktopMenu.querySelector('a[href*="/today"]')?.classList.add('menu-list__link--active');
            } else if (path.includes('/yoga')) {
              desktopMenu.querySelector('a[href*="/yoga"]')?.classList.add('menu-list__link--active');
            } else if (path.includes('/gyaan')) {
              desktopMenu.querySelector('a[href*="/gyaan"]')?.classList.add('menu-list__link--active');
            } else if (path.includes('/blogs/')) {
              desktopMenu.querySelector('a.menu-list__link--ayurveda-pill')?.classList.add('menu-list__link--active');
            }
          }
        }

        // Helper to replace footer policy links dynamically
        function fixFooterLinks() {
          var footerList = document.querySelector('.inline-policy-list');
          if (footerList) {
            footerList.innerHTML = `
              <li><a href="/pages/legal-center" class="footer-utilities__text">Legal center</a></li>
              <li><a href="/policies/terms-of-service" class="footer-utilities__text">Terms</a></li>
              <li><a href="/policies/privacy-policy" class="footer-utilities__text">Privacy</a></li>
              <li><a href="/policies/refund-policy" class="footer-utilities__text">Refund policy</a></li>
              <li><a href="/pages/health-disclaimer" class="footer-utilities__text">Health disclaimer</a></li>
            `;
          }

          // Hide English dropdown globally
          var langDropdown = document.querySelector('.dhyanhq-lang-dropdown');
          if (langDropdown) langDropdown.style.display = 'none';
        }

        // Run immediately and on DOMContentLoaded
        fixHeaderMenu();
        fixFooterLinks();
        window.addEventListener('DOMContentLoaded', function() {
          fixHeaderMenu();
          fixFooterLinks();
        });
      })();
    </script>

    {% render 'search-modal' %}

    {% if settings.quick_add or settings.mobile_quick_add %}
      {% render 'quick-add-modal' %}
    {% endif %}

    {%- if is_ayurveda_page -%}
      <div class="ayurhq-bottom-nav-container">
        <nav class="ayurhq-bottom-nav" aria-label="Mobile Navigation">
          
          <!-- Today -->
          {%- assign active_today = false -%}
          {%- assign today_path = current_blog_url | append: '/today' -%}
          {%- if current_path == today_path or current_path == today_path | append: '/' -%}
            {%- assign active_today = true -%}
          {%- endif -%}
          <a href="{{ today_path }}" class="ayurhq-bottom-nav__item{% if active_today %} ayurhq-bottom-nav__item--active{% endif %}">
            <span class="ayurhq-bottom-nav__icon">
              <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M5.5 16.5a6.5 6.5 0 0 1 13 0"></path>
                <line x1="3" y1="19.5" x2="21" y2="19.5"></line>
                <line x1="12" y1="4" x2="12" y2="6.4"></line>
                <line x1="5.2" y1="7.2" x2="6.9" y2="8.9"></line>
                <line x1="18.8" y1="7.2" x2="17.1" y2="8.9"></line>
              </svg>
            </span>
            <span>Today</span>
          </a>
 
          <!-- Yoga -->
          {%- assign active_yoga = false -%}
          {%- assign yoga_path = current_blog_url | append: '/yoga' -%}
          {%- if current_path == yoga_path or current_path == yoga_path | append: '/' -%}
            {%- assign active_yoga = true -%}
          {%- endif -%}
          <a href="{{ yoga_path }}" class="ayurhq-bottom-nav__item{% if active_yoga %} ayurhq-bottom-nav__item--active{% endif %}">
            <span class="ayurhq-bottom-nav__icon">
              <svg viewBox="0 0 256 256" width="22" height="22" fill="currentColor" aria-hidden="true">
                <path d="M245.83,121.63a15.53,15.53,0,0,0-9.52-7.33,73.51,73.51,0,0,0-22.17-2.22c4-19.85,1-35.55-2.06-44.86a16.15,16.15,0,0,0-18.79-10.88,85.53,85.53,0,0,0-28.55,12.12,94.58,94.58,0,0,0-27.11-33.25,16.05,16.05,0,0,0-19.26,0A94.48,94.48,0,0,0,91.26,68.46,85.53,85.53,0,0,0,62.71,56.34,16.15,16.15,0,0,0,43.92,67.22c-3,9.31-6,25-2.06,44.86a73.51,73.51,0,0,0-22.17,2.22,15.53,15.53,0,0,0-9.52,7.33,16,16,0,0,0-1.6,12.27c3.39,12.57,13.8,36.48,45.33,55.32S113.13,208,128.05,208s42.67,0,74-18.78c31.53-18.84,41.94-42.75,45.33-55.32A16,16,0,0,0,245.83,121.63ZM59.14,72.14a.2.2,0,0,1,.23-.15A70.43,70.43,0,0,1,85.18,83.66,118.65,118.65,0,0,0,80,119.17c0,18.74,3.77,34,9.11,46.28A123.59,123.59,0,0,1,69.57,140C51.55,108.62,55.3,84,59.14,72.14Zm3,103.35C35.47,159.57,26.82,140.05,24,129.7a59.82,59.82,0,0,1,22.5-1.17,129.08,129.08,0,0,0,9.15,19.41,142.28,142.28,0,0,0,34,39.56A114.92,114.92,0,0,1,62.1,175.49ZM128,190.4c-9.33-6.94-32-28.23-32-71.23C96,76.7,118.38,55.24,128,48c9.62,7.26,32,28.72,32,71.19C160,162.17,137.33,183.46,128,190.4ZM170.82,83.66A70.43,70.43,0,0,1,196.63,72a.2.2,0,0,1,.23.15C200.7,84,204.45,108.62,186.43,140a123.32,123.32,0,0,1-19.54,25.48c5.34-12.26,9.11-27.54,9.11-46.28A118.65,118.65,0,0,0,170.82,83.66ZM232,129.72c-2.77,10.25-11.4,29.81-38.09,45.77a114.92,114.92,0,0,1-27.55,12,142.28,142.28,0,0,0,34-39.56,129.08,129.08,0,0,0,9.15-19.41A59.69,59.69,0,0,1,232,129.71Z"></path>
              </svg>
            </span>
            <span>Yoga</span>
          </a>
 
          <!-- Guruji (Raised Center Button) -->
          {%- assign active_guruji = false -%}
          {%- if current_path == '/pages/consultation' or current_path == '/pages/consultation/' -%}
            {%- assign active_guruji = true -%}
          {%- endif -%}
          <a href="/pages/consultation" class="ayurhq-bottom-nav__item ayurhq-bottom-nav__item--guruji{% if active_guruji %} ayurhq-bottom-nav__item--active{% endif %}">
            <span class="ayurhq-bottom-nav__icon">
              <svg viewBox="-1 0 412 500" width="24" height="24" fill="none" stroke="currentColor" stroke-width="23" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M 205 14 C 202 80, 167 112, 149.5 150 C 127 182, 105.5 225, 105.5 278 C 105.5 322, 133 362, 156 384 C 168 393, 150 400, 125 404 C 95 402, 20 407, 12 445 C 6 466, 38 486, 88 487.5 C 138 489, 180 468, 205 426 L 205 398 C 215 388, 243.5 358, 243.5 318 C 242 286, 208 246, 205 228 C 202 246, 168 286, 166.5 318 C 166.5 358, 195 388, 205 398 L 205 426 C 230 468, 272 489, 322 487.5 C 372 486, 404 466, 398 445 C 390 407, 315 402, 285 404 C 260 400, 242 393, 254 384 C 277 362, 304.5 322, 304.5 278 C 304.5 225, 283 182, 260.5 150 C 243 112, 208 80, 205 14 Z M 126 404 C 146 414, 160 432, 170 448 M 284 404 C 264 414, 250 432, 240 448" />
              </svg>
            </span>
            <span>Guruji</span>
          </a>
 
          <!-- Gyaan -->
          {%- assign active_gyaan = false -%}
          {%- assign gyaan_path = current_blog_url | append: '/gyaan' -%}
          {%- if current_path == gyaan_path or current_path == gyaan_path | append: '/' -%}
            {%- assign active_gyaan = true -%}
          {%- endif -%}
          <a href="{{ gyaan_path }}" class="ayurhq-bottom-nav__item{% if active_gyaan %} ayurhq-bottom-nav__item--active{% endif %}">
            <span class="ayurhq-bottom-nav__icon">
              <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M12 5.8 C 9.7 4.4 6.6 4.3 4 5.3 V18 c2.6-1 5.7-.9 8 .5 c2.3-1.4 5.4-1.5 8-.5 V5.3 c-2.6-1-5.7-.9-8 .5 Z"></path>
                <line x1="12" y1="6" x2="12" y2="18.2"></line>
              </svg>
            </span>
            <span>Gyaan</span>
          </a>
 
          <!-- Ayurveda (Active Link on Ayurveda Hub & Article templates) -->
          {%- assign active_ayurveda = false -%}
          {%- if current_path == current_blog_url or current_path == current_blog_url | append: '/' or template.name == 'blog' or template.name == 'article' or template.name == '404' -%}
